        {
          "name": "/Account/v1/User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parse response JSON",
                  "let response = pm.response.json();",
                  "",
                  "// Validate Status Code",
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "// Validate userID exists",
                  "pm.test(\"UserID exists\", function () {",
                  "    pm.expect(response.userID).to.exist;",
                  "});",
                  "",
                  "// Validate username exists",
                  "pm.test(\"Username exists\", function () {",
                  "    pm.expect(response.username).to.exist;",
                  "});",
                  "",
                  "// Set Environment Variables",
                  "pm.environment.set(\"userID\", response.userID);",
                  "pm.environment.set(\"username\", response.username);",
                  "",
                  "console.log(\"Environment Variables Set\");",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
