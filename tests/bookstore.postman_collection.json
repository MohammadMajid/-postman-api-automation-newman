          "name": "/Account/v1/GenerateToken",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Validate Status Code",
                  "pm.test(\"Status Code is 200\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Parse JSON",
                  "const body = pm.response.json();",
                  "",
                  "// Validate authorization success",
                  "pm.test(\"Authorization successful\", () => {",
                  "    pm.expect(body.status).to.eql(\"Success\");",
                  "    pm.expect(body.token).to.exist;",
                  "});",
                  "",
                  "// Set Environment Variables",
                  "pm.environment.set(\"authToken\", body.token);",
                  "pm.environment.set(\"tokenExpiry\", body.expires);",
                  "",
                  "console.log(\"Token Saved:\", body.token);",
                  ""
